# Database
DATABASE_URL=postgresql://user:password@localhost:5432/helptidesk

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRATION=7d

# Twilio (obtener desde https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here

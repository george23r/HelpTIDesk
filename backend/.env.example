# Email (Gmail)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Frontend
REACT_APP_API_URL=http://localhost:3001

# Node Environment
NODE_ENV=development
API_PORT=3001

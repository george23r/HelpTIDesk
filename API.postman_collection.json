    {
      "name": "Tickets",
      "item": [
        {
          "name": "Crear Ticket (enviará emails/SMS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE",
                "description": "Reemplaza con el token obtenido del login"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Problema con el servidor\",\n  \"description\": \"El servidor de producción está caído desde las 10:00 AM\",\n  \"priority\": \"URGENT\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/tickets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["tickets"]
            }
          }
        },
        {
          "name": "Obtener Todos los Tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/tickets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["tickets"]
            }
          }
        },
        {
          "name": "Obtener Ticket Específico",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/tickets/TICKET_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["tickets", "TICKET_ID_HERE"]
            }
          }
        },
        {
          "name": "Actualizar Ticket",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"assignedToId\": \"USER_ID_HERE\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/tickets/TICKET_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["tickets", "TICKET_ID_HERE"]
            }
          }
        },
        {
          "name": "Eliminar Ticket",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/tickets/TICKET_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["tickets", "TICKET_ID_HERE"]
            }
          }
        }
      ]
    },
